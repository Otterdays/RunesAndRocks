# Runes & Rocks — Environment Variables
# Copy to .env and fill in values. .env is gitignored.

# Game server
PORT=25565

# PostgreSQL (cold storage)
JDBC_URL=jdbc:postgresql://localhost:5432/runesandrocks
DB_USER=runes_admin
DB_PASS=runes_password

# Redis (hot cache)
REDIS_HOST=localhost
REDIS_PORT=6379

# Client (optional — when connecting from a different machine)
# SERVER_PORT=25565
